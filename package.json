{
  "name": "qyl.at",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check && tsc --noEmit && node scripts/check-dependencies.mjs",
    "build:site": "astro build && pagefind --site dist",
    "build": "npm run check && npm run build:site",
    "test:unit": "node --test tests/vitals.test.ts",
    "test:gates": "node scripts/check-artifacts.mjs && npm run test:unit && playwright test",
    "test": "npm run build && npm run test:gates",
    "smoke": "npm test",
    "preview": "wrangler dev",
    "deploy": "npm test && wrangler deploy",
    "deploy:dry": "npm run build && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.221.0",
    "@opentelemetry/resources": "^2.10.0",
    "@opentelemetry/sdk-logs": "^0.221.0",
    "web-vitals": "^6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.3",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24.10.0",
    "@types/pngjs": "^6.0.5",
    "astro": "7.1.3",
    "fontaine": "^0.8.0",
    "pagefind": "^1.5.2",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "8.1.5",
    "wrangler": "^4.113.0"
  },
  "overrides": {
    "miniflare": {
      "sharp": "0.35.0"
    }
  }
}
