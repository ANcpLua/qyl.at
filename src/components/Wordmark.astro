  <svg aria-hidden="true" viewBox="0 0 28 28" width="28" height="28">
    <path d="M4.5 8.25 14 2.75l9.5 5.5v11L14 24.75l-9.5-5.5z" fill="none" stroke="currentColor" stroke-width="1.5"></path>
    <path d="M8.25 10.25h7.5l4 3.75-4 3.75h-7.5l4-3.75z" fill="currentColor"></path>
